PORT=5122
NODE_ENV=development

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h

# Voter pseudonym: SHA-256(studentCode + electionId + VOTER_ID_SALT)
VOTER_ID_SALT=upb-voting-salt-change-me

# Enrollment: mock | database | api  (default: database if DATABASE_URL set, else mock)
ENROLLMENT_SOURCE=database

# Mock UPB without PostgreSQL (set ENROLLMENT_SOURCE=mock)
MOCK_UPB_ENROLLMENT=false

# PostgreSQL — mock UPB registry in `students` table
DATABASE_URL=postgresql://voting:voting@localhost:5432/voting_upb

# Real UPB HTTP API (ENROLLMENT_SOURCE=api)
UPB_API_URL=
UPB_API_KEY=

# Fallback organizer if DB empty (dev only)
ADMIN_EMAIL=admin@upb.ro
ADMIN_PASSWORD=admin

# Blockchain (local Hardhat / Besu)
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
VOTING_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
ORACLE_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
